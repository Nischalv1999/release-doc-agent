# ===== LLM Provider Configuration =====
# Choose one: "openai" or "anthropic"
LLM_PROVIDER=openai

# --- Option A: OpenAI (default) ---
# Get key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini

# --- Option B: Anthropic (Claude) ---
# Get key at: https://console.anthropic.com/settings/keys
# ANTHROPIC_API_KEY=sk-ant-your-key-here
# ANTHROPIC_MODEL=claude-sonnet-4-20250514
# LLM_PROVIDER=anthropic

# Note: If using Anthropic for generation, you can optionally set
# OPENAI_API_KEY too for higher-quality embeddings (RAG).
# Without it, a local fallback embedding is used (works but less accurate).
