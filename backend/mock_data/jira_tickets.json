  {
    "id": "98010",
    "key": "PLAT-2010",
    "self": "https://company.atlassian.net/rest/api/3/issue/98010",
    "fields": {
      "summary": "Real-time WebSocket notification service",
      "description": {
        "type": "doc",
        "version": 1,
        "content": [
          {
            "type": "paragraph",
            "content": [{ "type": "text", "text": "As a user, I want to receive real-time notifications (payment events, security alerts) so I don't have to refresh the page or wait for email." }]
          },
          {
            "type": "heading",
            "attrs": { "level": 3 },
            "content": [{ "type": "text", "text": "Acceptance Criteria" }]
          },
          {
            "type": "bulletList",
            "content": [
              { "type": "listItem", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "WebSocket endpoint at /ws, authenticated via JWT in query string" }] }] },
              { "type": "listItem", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "Server sends notification events: payment_succeeded, payment_failed, subscription_renewed, subscription_canceled, invoice_generated, security_alert" }] }] },
              { "type": "listItem", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "Notifications persisted in DB for offline users; delivered on reconnect" }] }] },
              { "type": "listItem", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "Client SDK with exponential backoff reconnect (max delay 30s)" }] }] },
              { "type": "listItem", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "Load test: 1000 concurrent connections, no memory leak over 30 minutes" }] }] }
            ]
          },
          {
            "type": "heading",
            "attrs": { "level": 3 },
            "content": [{ "type": "text", "text": "Out of Scope" }]
          },
          {
            "type": "paragraph",
            "content": [{ "type": "text", "text": "Push notifications (mobile) are out of scope for this ticket. Email notifications are handled separately." }]
          }
        ]
      },
      "status": { "id": "10001", "name": "Done", "statusCategory": { "id": 3, "key": "done", "name": "Done" } },
      "priority": { "id": "2", "name": "High" },
      "issuetype": { "id": "10001", "name": "Story", "subtask": false },
      "assignee": { "displayName": "Marcus Chen", "emailAddress": "marcus.chen@company.com", "accountId": "uid-10207" },
      "reporter": { "displayName": "Head of Product", "emailAddress": "head-of-product@company.com", "accountId": "uid-90002" },
      "labels": ["notifications", "websocket", "real-time"],
      "created": "2024-03-01T10:00:00.000+0000",
      "updated": "2024-03-21T12:00:00.000+0000",
      "resolutiondate": "2024-03-21T12:00:00.000+0000",
      "customfield_10016": 8,
      "customfield_10014": "PLAT-2001",
      "customfield_10020": { "id": 52, "name": "Sprint 52", "state": "closed" },
      "components": [{ "id": "c004", "name": "Notifications" }],
      "fixVersions": [{ "id": "v2.5.0", "name": "v2.5.0", "released": false }],
      "subtasks": [],
      "comment": { "total": 1, "comments": [
        { "id": "c010", "author": { "displayName": "Marcus Chen" }, "body": { "type": "doc", "version": 1, "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "Load test passed: 1000 connections, RSS stable at 380MB after 30min. PR #205 merged." }] }] }, "created": "2024-03-21T12:00:00.000+0000" }
      ]}
    }
  },
  {
    "id": "98015",
    "key": "PLAT-2015",
    "self": "https://company.atlassian.net/rest/api/3/issue/98015",
    "fields": {
      "summary": "Dashboard summary endpoint takes >10s for orgs with 1000+ members",
      "description": {
        "type": "doc",
        "version": 1,
        "content": [
          {
            "type": "paragraph",
            "content": [{ "type": "text", "text": "Reported by customer success: Enterprise org 'Acme Corp' (1,240 members) experiences 12-18 second load times on the dashboard. DataDog shows the /api/v2/dashboard/summary endpoint making 1,241 queries per request." }]
          },
          {
            "type": "heading",
            "attrs": { "level": 3 },
            "content": [{ "type": "text", "text": "Root Cause" }]
          },
          {
            "type": "paragraph",
            "content": [{ "type": "text", "text": "The aggregation code fetches all org members then loops issuing individual COUNT(*) queries per member. This is an N+1 pattern." }]
          },
          {
            "type": "heading",
            "attrs": { "level": 3 },
            "content": [{ "type": "text", "text": "Expected Behavior" }]
          },
          {
            "type": "paragraph",
            "content": [{ "type": "text", "text": "Dashboard should load in <500ms for any org size. Single aggregation query." }]
          },
          {
            "type": "heading",
            "attrs": { "level": 3 },
            "content": [{ "type": "text", "text": "Steps to Reproduce" }]
          },
          {
            "type": "orderedList",
            "content": [
              { "type": "listItem", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "Log in as a user in an org with 1000+ members" }] }] },
              { "type": "listItem", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "Navigate to Dashboard" }] }] },
              { "type": "listItem", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "Observe: page load exceeds 10 seconds" }] }] }
            ]
          }
        ]
      },
      "status": { "id": "10001", "name": "Done", "statusCategory": { "id": 3, "key": "done", "name": "Done" } },
      "priority": { "id": "2", "name": "High" },
      "issuetype": { "id": "10004", "name": "Bug", "subtask": false },
      "assignee": { "displayName": "Aisha Okonkwo", "emailAddress": "aisha.okonkwo@company.com", "accountId": "uid-10210" },
      "reporter": { "displayName": "Support Engineer", "emailAddress": "support@company.com", "accountId": "uid-90010" },
      "labels": ["performance", "database", "enterprise", "regression"],
      "created": "2024-03-10T14:00:00.000+0000",
      "updated": "2024-03-22T08:00:00.000+0000",
      "resolutiondate": "2024-03-22T08:00:00.000+0000",
      "customfield_10016": 5,
      "customfield_10014": "PLAT-2001",
      "customfield_10020": { "id": 52, "name": "Sprint 52", "state": "closed" },
      "components": [{ "id": "c005", "name": "Dashboard" }, { "id": "c003", "name": "Database" }],
      "fixVersions": [{ "id": "v2.5.0", "name": "v2.5.0", "released": false }],
      "subtasks": [],
      "comment": { "total": 3, "comments": [
        { "id": "c015a", "author": { "displayName": "Aisha Okonkwo" }, "body": { "type": "doc", "version": 1, "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "Confirmed N+1. Replacing with single CTE query. Staging: 12,000ms → 95ms for 1,200-member org." }] }] }, "created": "2024-03-21T10:00:00.000+0000" }
      ]}
    }
  },
  {
    "id": "98016",
    "key": "PLAT-2016",
    "self": "https://company.atlassian.net/rest/api/3/issue/98016",
    "fields": {
      "summary": "Add composite indexes to user_events and org_reports for reporting queries",
      "description": {
        "type": "doc",
        "version": 1,
        "content": [
          {
            "type": "paragraph",
            "content": [{ "type": "text", "text": "The user_events table (~32M rows, growing 500k/day) and org_reports table are doing sequential scans for common dashboard and reporting queries. Composite indexes needed." }]
          },
          {
            "type": "heading",
            "attrs": { "level": 3 },
            "content": [{ "type": "text", "text": "Required Indexes" }]
          },
          {
            "type": "bulletList",
            "content": [
              { "type": "listItem", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "user_events(org_id, created_at DESC) — dashboard 30-day range scans" }] }] },
              { "type": "listItem", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "user_events(org_id, event_type, created_at DESC) — event-type analytics" }] }] },
              { "type": "listItem", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "org_reports(org_id, period_start, period_end) — billing period reports" }] }] },
              { "type": "listItem", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "payments(org_id, processor, status, created_at DESC) — billing dashboard" }] }] }
            ]
          },
          {
            "type": "paragraph",
            "content": [{ "type": "text", "text": "Use CREATE INDEX CONCURRENTLY to avoid table locks in production." }]
          }
        ]
      },
      "status": { "id": "10001", "name": "Done", "statusCategory": { "id": 3, "key": "done", "name": "Done" } },
      "priority": { "id": "3", "name": "Medium" },
      "issuetype": { "id": "10003", "name": "Task", "subtask": false },
      "assignee": { "displayName": "Aisha Okonkwo", "emailAddress": "aisha.okonkwo@company.com", "accountId": "uid-10210" },
      "reporter": { "displayName": "Aisha Okonkwo", "emailAddress": "aisha.okonkwo@company.com", "accountId": "uid-10210" },
      "labels": ["database", "performance"],
      "created": "2024-03-15T09:00:00.000+0000",
