  {
    "id": "98001",
    "key": "PLAT-2001",
    "self": "https://company.atlassian.net/rest/api/3/issue/98001",
    "fields": {
      "summary": "Platform Modernization - v2.5.0 Epic",
      "description": {
        "type": "doc",
        "version": 1,
        "content": [
          {
            "type": "paragraph",
            "content": [{ "type": "text", "text": "Epic tracking all v2.5.0 platform modernization work. Covers: Stripe integration, WebSocket notifications, database performance, API hardening (rate limiting + security), and removal of deprecated v1 APIs." }]
          },
          {
            "type": "heading",
            "attrs": { "level": 3 },
            "content": [{ "type": "text", "text": "Goals" }]
          },
          {
            "type": "bulletList",
            "content": [
              { "type": "listItem", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "Support Stripe as a payment processor alongside PayPal" }] }] },
              { "type": "listItem", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "Deliver real-time notifications via WebSocket to eliminate client polling" }] }] },
              { "type": "listItem", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "Fix dashboard performance regression for large orgs (PLAT-2015)" }] }] },
              { "type": "listItem", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "Harden API with rate limiting and fix critical security vulnerability (PLAT-2025)" }] }] },
              { "type": "listItem", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "Complete removal of deprecated v1 endpoints and legacy JWT fields" }] }] }
            ]
          }
        ]
      },
      "status": { "id": "10001", "name": "Done", "statusCategory": { "id": 3, "key": "done", "name": "Done" } },
      "priority": { "id": "1", "name": "Highest" },
      "issuetype": { "id": "10000", "name": "Epic", "subtask": false },
      "assignee": { "displayName": "Priya Kapoor", "emailAddress": "priya.kapoor@company.com", "accountId": "uid-10201" },
      "reporter": { "displayName": "Director of Engineering", "emailAddress": "engineering-director@company.com", "accountId": "uid-90001" },
      "labels": ["q1-2024", "platform", "modernization"],
      "created": "2024-02-15T10:00:00.000+0000",
      "updated": "2024-03-24T14:00:00.000+0000",
      "resolutiondate": "2024-03-24T14:00:00.000+0000",
