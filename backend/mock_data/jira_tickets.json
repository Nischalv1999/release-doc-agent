  {
    "id": "98025",
    "key": "PLAT-2025",
    "self": "https://company.atlassian.net/rest/api/3/issue/98025",
    "fields": {
      "summary": "CRITICAL: SQL injection vulnerability in /api/v2/search endpoint (CVE-2024-31337)",
      "description": {
        "type": "doc",
        "version": 1,
        "content": [
          {
            "type": "paragraph",
            "content": [{ "type": "text", "text": "SECURITY VULNERABILITY — Do not discuss publicly until patched." }]
          },
          {
            "type": "paragraph",
            "content": [{ "type": "text", "text": "The GET /api/v2/search endpoint interpolates the 'q' query parameter and 'filters' parameter directly into a raw SQL string using string concatenation. An authenticated attacker can exfiltrate arbitrary row data from the database." }]
          },
          {
            "type": "heading",
            "attrs": { "level": 3 },
            "content": [{ "type": "text", "text": "Proof of Concept" }]
          },
          {
            "type": "paragraph",
            "content": [{ "type": "text", "text": "GET /api/v2/search?q=x%27+UNION+SELECT+email,password_hash,null+FROM+users+--  returns user credentials from other orgs." }]
          },
          {
            "type": "heading",
            "attrs": { "level": 3 },
            "content": [{ "type": "text", "text": "CVE Details" }]
          },
          {
            "type": "bulletList",
            "content": [
              { "type": "listItem", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "CVE: CVE-2024-31337" }] }] },
              { "type": "listItem", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "CVSS Score: 9.1 (Critical)" }] }] },
              { "type": "listItem", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "Attack vector: Network, privileges required: Low (authenticated user)" }] }] }
            ]
          },
          {
            "type": "heading",
            "attrs": { "level": 3 },
            "content": [{ "type": "text", "text": "Fix" }]
          },
          {
            "type": "paragraph",
            "content": [{ "type": "text", "text": "Replace db.rawSearch() with ORM parameterized queries. Delete the rawSearch helper entirely. Also upgrade axios (CVE-2024-39338 SSRF) and lodash (CVE-2021-23337 prototype pollution) as part of this fix." }]
          }
        ]
      },
      "status": { "id": "10001", "name": "Done", "statusCategory": { "id": 3, "key": "done", "name": "Done" } },
      "priority": { "id": "1", "name": "Highest" },
      "issuetype": { "id": "10004", "name": "Bug", "subtask": false },
      "assignee": { "displayName": "Elena Vasquez", "emailAddress": "elena.vasquez@company.com", "accountId": "uid-10215" },
      "reporter": { "displayName": "Security Team", "emailAddress": "security@company.com", "accountId": "uid-90005" },
      "labels": ["security", "critical", "cve", "sql-injection"],
      "created": "2024-03-20T16:00:00.000+0000",
      "updated": "2024-03-23T14:00:00.000+0000",
      "resolutiondate": "2024-03-23T14:00:00.000+0000",
      "customfield_10016": 3,
      "customfield_10014": "PLAT-2001",
      "customfield_10020": { "id": 52, "name": "Sprint 52", "state": "closed" },
      "components": [{ "id": "c006", "name": "API" }, { "id": "c007", "name": "Security" }],
      "fixVersions": [{ "id": "v2.5.0", "name": "v2.5.0", "released": false }],
      "subtasks": [],
      "comment": { "total": 2, "comments": [
        { "id": "c025a", "author": { "displayName": "Elena Vasquez" }, "body": { "type": "doc", "version": 1, "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "Fix implemented and reviewed. Pen test confirms injection no longer possible. Upgrading axios and lodash in same PR." }] }] }, "created": "2024-03-23T10:00:00.000+0000" }
      ]}
    }
  },
  {
    "id": "98026",
    "key": "PLAT-2026",
    "self": "https://company.atlassian.net/rest/api/3/issue/98026",
    "fields": {
      "summary": "Remove deprecated /api/v1/* endpoints and legacy JWT fields",
      "description": {
        "type": "doc",
        "version": 1,
        "content": [
          {
            "type": "paragraph",
            "content": [{ "type": "text", "text": "The /api/v1/* endpoints were deprecated in v2.3.0 (released 2024-01-10) with a 6-month migration notice. v2.5.0 is the removal release." }]
          },
          {
            "type": "heading",
            "attrs": { "level": 3 },
            "content": [{ "type": "text", "text": "Endpoints to Remove" }]
          },
          {
            "type": "bulletList",
            "content": [
              { "type": "listItem", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "GET/POST /api/v1/users (use /api/v2/users)" }] }] },
              { "type": "listItem", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "GET/POST /api/v1/organizations (use /api/v2/orgs)" }] }] },
              { "type": "listItem", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "POST /api/v1/auth/login (use /api/v2/auth/token)" }] }] },
              { "type": "listItem", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "GET /api/v1/billing (use /api/v2/payments/history)" }] }] },
              { "type": "listItem", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "All /api/v1/webhooks/* (use /api/v2/webhooks/*)" }] }] }
            ]
          },
          {
            "type": "heading",
            "attrs": { "level": 3 },
            "content": [{ "type": "text", "text": "JWT Changes" }]
          },
          {
            "type": "bulletList",
            "content": [
              { "type": "listItem", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "Remove 'legacy_uid' claim (deprecated since v2.0; use 'sub')" }] }] },
              { "type": "listItem", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "Add 'jti' (JWT ID) claim for token revocation support" }] }] }
            ]
          },
          {
            "type": "paragraph",
            "content": [{ "type": "text", "text": "BREAKING: All existing JWT tokens become invalid after deploy. Coordinate with customer success — users will see a forced login prompt. Also delete src/api/v1/ directory entirely." }]
          }
        ]
      },
      "status": { "id": "10001", "name": "Done", "statusCategory": { "id": 3, "key": "done", "name": "Done" } },
      "priority": { "id": "3", "name": "Medium" },
      "issuetype": { "id": "10003", "name": "Task", "subtask": false },
      "assignee": { "displayName": "Ben Okafor", "emailAddress": "ben.okafor@company.com", "accountId": "uid-10218" },
