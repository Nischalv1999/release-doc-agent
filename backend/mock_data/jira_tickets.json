  {
    "id": "98020",
    "key": "PLAT-2020",
    "self": "https://company.atlassian.net/rest/api/3/issue/98020",
    "fields": {
      "summary": "Implement API rate limiting to prevent abuse and protect backend",
      "description": {
        "type": "doc",
        "version": 1,
        "content": [
          {
            "type": "paragraph",
            "content": [{ "type": "text", "text": "We've observed abusive request patterns from both unauthenticated scrapers and authenticated bulk-API clients. Rate limiting is needed to protect backend services and ensure fair usage." }]
          },
          {
            "type": "heading",
            "attrs": { "level": 3 },
            "content": [{ "type": "text", "text": "Requirements" }]
          },
          {
            "type": "bulletList",
            "content": [
              { "type": "listItem", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "Token bucket algorithm (allows short bursts)" }] }] },
              { "type": "listItem", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "Redis-backed for multi-instance correctness; in-memory LRU fallback" }] }] },
              { "type": "listItem", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "Default limit: 300 req/min per org (authenticated)" }] }] },
              { "type": "listItem", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "Unauthenticated: 30 req/min per IP" }] }] },
              { "type": "listItem", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "Search endpoint: 60 req/min per org (tighter due to DB cost)" }] }] },
              { "type": "listItem", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "HTTP 429 with Retry-After header on limit exceeded" }] }] },
              { "type": "listItem", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "Health check endpoint exempt" }] }] }
            ]
          }
        ]
      },
