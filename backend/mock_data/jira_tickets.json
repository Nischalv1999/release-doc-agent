  {
    "id": "98002",
    "key": "PLAT-2002",
    "self": "https://company.atlassian.net/rest/api/3/issue/98002",
    "fields": {
      "summary": "Integrate Stripe as payment processor (checkout, subscriptions, webhooks)",
      "description": {
        "type": "doc",
        "version": 1,
        "content": [
          {
            "type": "paragraph",
            "content": [{ "type": "text", "text": "As a customer, I want to pay via Stripe so I can use cards, Apple Pay, and Google Pay in addition to PayPal." }]
          },
          {
            "type": "heading",
            "attrs": { "level": 3 },
            "content": [{ "type": "text", "text": "Acceptance Criteria" }]
          },
          {
            "type": "bulletList",
            "content": [
              { "type": "listItem", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "POST /api/v2/payments/checkout returns a Stripe Checkout Session URL" }] }] },
              { "type": "listItem", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "Stripe webhooks handled idempotently for checkout.session.completed, payment_intent.succeeded, payment_intent.payment_failed" }] }] },
              { "type": "listItem", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "Subscription create/cancel/upgrade via Stripe Subscriptions API" }] }] },
              { "type": "listItem", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "Stripe customer.subscription.updated and .deleted events sync to local DB" }] }] },
              { "type": "listItem", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "End-to-end test passes in Stripe test mode" }] }] }
            ]
          },
          {
            "type": "heading",
            "attrs": { "level": 3 },
            "content": [{ "type": "text", "text": "Technical Notes" }]
          },
          {
            "type": "paragraph",
            "content": [{ "type": "text", "text": "Use Stripe SDK v14.x (TypeScript). Webhook secret must be rotated per environment. Idempotency keys required on all Stripe mutation calls. See PLAT-2003 for schema migration." }]
          }
        ]
      },
      "status": { "id": "10001", "name": "Done", "statusCategory": { "id": 3, "key": "done", "name": "Done" } },
      "priority": { "id": "2", "name": "High" },
      "issuetype": { "id": "10001", "name": "Story", "subtask": false },
      "assignee": { "displayName": "Priya Kapoor", "emailAddress": "priya.kapoor@company.com", "accountId": "uid-10201" },
      "reporter": { "displayName": "Head of Product", "emailAddress": "head-of-product@company.com", "accountId": "uid-90002" },
      "labels": ["payments", "stripe", "q1-2024"],
      "created": "2024-02-20T09:00:00.000+0000",
      "updated": "2024-03-20T16:00:00.000+0000",
      "resolutiondate": "2024-03-20T16:00:00.000+0000",
      "customfield_10016": 13,
      "customfield_10014": "PLAT-2001",
      "customfield_10020": { "id": 52, "name": "Sprint 52", "state": "closed" },
      "components": [{ "id": "c002", "name": "Payments" }],
      "fixVersions": [{ "id": "v2.5.0", "name": "v2.5.0", "released": false }],
      "subtasks": [],
      "comment": { "total": 2, "comments": [
        { "id": "c002", "author": { "displayName": "Priya Kapoor" }, "body": { "type": "doc", "version": 1, "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "PR #201 merged. Staging verified with Stripe test mode. Ready for release." }] }] }, "created": "2024-03-20T17:00:00.000+0000" }
      ]}
    }
  },
  {
    "id": "98003",
    "key": "PLAT-2003",
    "self": "https://company.atlassian.net/rest/api/3/issue/98003",
    "fields": {
      "summary": "Migrate payment/subscription data model to support multiple processors",
      "description": {
        "type": "doc",
        "version": 1,
        "content": [
          {
            "type": "paragraph",
            "content": [{ "type": "text", "text": "The current payment schema is tightly coupled to PayPal (e.g. paypal_subscription_id column). To support Stripe and future processors, the schema must be generalized." }]
          },
          {
            "type": "heading",
            "attrs": { "level": 3 },
            "content": [{ "type": "text", "text": "Acceptance Criteria" }]
          },
          {
            "type": "bulletList",
            "content": [
              { "type": "listItem", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "payments table has processor enum column (stripe | paypal)" }] }] },
              { "type": "listItem", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "subscriptions.paypal_subscription_id renamed to external_subscription_id" }] }] },
              { "type": "listItem", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "subscriptions.processor column added (not null)" }] }] },
              { "type": "listItem", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "Existing PayPal subscriptions backfilled with processor='paypal'" }] }] },
              { "type": "listItem", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "Down migration script tested and verified" }] }] }
            ]
          },
          {
            "type": "paragraph",
            "content": [{ "type": "text", "text": "BREAKING: TypeScript Subscription and Payment interfaces updated. All callers must be updated. API clients reading paypalSubscriptionId must use externalSubscriptionId." }]
          }
        ]
      },
      "status": { "id": "10001", "name": "Done", "statusCategory": { "id": 3, "key": "done", "name": "Done" } },
      "priority": { "id": "2", "name": "High" },
      "issuetype": { "id": "10001", "name": "Story", "subtask": false },
      "assignee": { "displayName": "Priya Kapoor", "emailAddress": "priya.kapoor@company.com", "accountId": "uid-10201" },
      "reporter": { "displayName": "Head of Product", "emailAddress": "head-of-product@company.com", "accountId": "uid-90002" },
      "labels": ["payments", "database", "breaking-change", "q1-2024"],
      "created": "2024-02-20T09:30:00.000+0000",
      "updated": "2024-03-20T16:00:00.000+0000",
      "resolutiondate": "2024-03-20T16:00:00.000+0000",
      "customfield_10016": 8,
      "customfield_10014": "PLAT-2001",
      "customfield_10020": { "id": 52, "name": "Sprint 52", "state": "closed" },
      "components": [{ "id": "c002", "name": "Payments" }, { "id": "c003", "name": "Database" }],
      "fixVersions": [{ "id": "v2.5.0", "name": "v2.5.0", "released": false }],
      "subtasks": [],
      "comment": { "total": 1, "comments": [] }
    }
