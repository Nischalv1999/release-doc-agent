  {
    "id": "98004",
    "key": "PLAT-2004",
    "self": "https://company.atlassian.net/rest/api/3/issue/98004",
    "fields": {
      "summary": "Payment history API with cursor-based pagination",
      "description": {
        "type": "doc",
        "version": 1,
        "content": [
          {
            "type": "paragraph",
            "content": [{ "type": "text", "text": "As a customer admin, I want to view a paginated list of all payments so I can reconcile invoices without loading all records at once." }]
          },
          {
            "type": "heading",
            "attrs": { "level": 3 },
            "content": [{ "type": "text", "text": "Acceptance Criteria" }]
          },
          {
            "type": "bulletList",
            "content": [
              { "type": "listItem", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "GET /api/v2/payments/history returns paginated results (default page size 20, max 100)" }] }] },
              { "type": "listItem", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "Cursor-based pagination: response includes nextCursor; request accepts after= param" }] }] },
              { "type": "listItem", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "Filterable by status (pending | succeeded | failed | refunded), processor (stripe | paypal), and date range" }] }] },
              { "type": "listItem", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "Results ordered by createdAt DESC" }] }] }
            ]
          }
        ]
      },
      "status": { "id": "10001", "name": "Done", "statusCategory": { "id": 3, "key": "done", "name": "Done" } },
      "priority": { "id": "3", "name": "Medium" },
      "issuetype": { "id": "10001", "name": "Story", "subtask": false },
      "assignee": { "displayName": "Vikram Nair", "emailAddress": "vikram.nair@company.com", "accountId": "uid-10204" },
      "reporter": { "displayName": "Head of Product", "emailAddress": "head-of-product@company.com", "accountId": "uid-90002" },
      "labels": ["payments", "api"],
      "created": "2024-03-01T09:00:00.000+0000",
      "updated": "2024-03-20T10:00:00.000+0000",
      "resolutiondate": "2024-03-20T10:00:00.000+0000",
